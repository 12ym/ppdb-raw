rules_version = '2';

// Aturan keamanan Firestore untuk PPDB RA Al Washliyah.
// Cara pakai: buka Firebase Console > Firestore Database > tab "Rules",
// hapus isi default, tempel seluruh isi file ini, lalu klik "Publish".

service cloud.firestore {
  match /databases/{database}/documents {

    // Koleksi "siswa" menyimpan data pendaftar PPDB.
    // - create: siapa pun boleh mendaftar lewat formulir publik
    // - read   : diperlukan agar fitur "Cek Status" (nomor pendaftaran + No. WA) bisa bekerja
    // - update : diperlukan agar Panel Admin bisa mengubah status & catatan biaya
    // - delete : dimatikan, data pendaftar tidak bisa dihapus dari sisi situs
    match /siswa/{regNo} {
      allow create: if request.resource.data.keys().hasAll(['namaAnak', 'noWa', 'status'])
                    && request.resource.data.namaAnak is string
                    && request.resource.data.noWa is string;
      allow read: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Semua koleksi/dokumen lain diblokir total secara default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
